# Core identity
ASSISTANT_NAME=CribClaw
ASSISTANT_HAS_OWN_NUMBER=true
PRIMARY_CHANNEL=telegram
TELEGRAM_BOT_TOKEN=
# Optional: force timezone for reminders and visual summaries (e.g. America/New_York)
TZ=
# Voice-note transcription:
# Local-first: install whisper.cpp or whisper CLI and set model path.
# Optional local model path for whisper.cpp:
WHISPER_MODEL_PATH=
# Optional API fallback only if local transcription is unavailable:
CRIBCLAW_STT_MODEL=whisper-1
# Max ms for one-shot LLM calls (event extraction, quick answers, voice fallback agent)
ONE_SHOT_CONTAINER_TIMEOUT=45000
# Fine-grained LLM-first limits (kept short for responsive chat)
CRIBCLAW_LLM_EXTRACT_TIMEOUT_MS=15000
CRIBCLAW_LLM_QUERY_TIMEOUT_MS=25000

# CribClaw family mode
# Keep these defaults for safest local setup.
CRIBCLAW_ENABLED=true
CRIBCLAW_FAMILY_FOLDER=family
CRIBCLAW_RUNTIME_MODE=locked
CRIBCLAW_ALLOW_ASSISTANT_TASKS=false
# Comma-separated sender IDs that can use builder mode tasks
CRIBCLAW_OWNER_SENDERS=
# LLM-first extraction with parser fallback
CRIBCLAW_LLM_FIRST=true
# Set false for strict LLM-only logging (no parser event fallback)
CRIBCLAW_PARSER_FALLBACK=true
# Auto reminders after last feed (minutes, comma-separated)
CRIBCLAW_FEED_REMINDERS_ENABLED=true
CRIBCLAW_FEED_REMINDER_MINUTES=120,180

# Baby's name (shown in visual summaries and reports)
CRIBCLAW_BABY_NAME=

# Easiest local setup:
#   npm run cribclaw:setup
